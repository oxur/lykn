{
    "name": "@lykn/lykn",
    "version": "0.3.1",
    "exports": "./src/index.d.ts",
    "nodeModulesDir": "none",
    "imports": {
        "astring": "npm:astring@^1.9.0"
    },
    "tasks": {
        "build": "deno run -A build.js",
        "build:browser": "deno run -A build.js",
        "test": "deno test -A test/",
        "test:unit": "deno test test/forms/ test/reader/ test/expander/",
        "test:integration": "deno test -A test/integration/",
        "check": "deno lint src/ && deno test -A test/",
        "expand": "deno eval \"import { read } from './src/reader.js'; import { expand } from './src/expander.js'; const src = Deno.readTextFileSync(Deno.args[0]); for (const form of expand(read(src))) console.log(JSON.stringify(form));\" --",
        "publish:jsr": "deno publish",
        "publish:jsr:dry": "deno publish --dry-run",
        "publish:npm": "npm publish --access public",
        "publish:npm:dry": "npm pack --dry-run"
    }
}
