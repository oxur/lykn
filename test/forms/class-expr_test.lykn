(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "../../packages/lang/compiler.js" ((alias compile raw-compile)))
(import "../../packages/lang/reader.js" (read))

(func compile :args (:string source) :body (bind r (raw-compile (read source))) (r:trim))

(test "class-expr: basic"
  (bind result (compile "(const MyClass (class-expr () (constructor () (return))))"))
  (includes result "class")
  (includes result "constructor"))

(test "class-expr: with extends"
  (bind result (compile "(const Sub (class-expr (Base) (constructor () (super))))"))
  (includes result "extends Base"))
