(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test "tag: basic tagged template"
  (bind result (compile-both "(tag html (template \"<div>\" content \"</div>\"))"))
  (includes result "html`")
  (includes result "${content}"))

;; DD-58 deferral: JS compiler double-escapes backslashes in template
;; content (same bug Rust had pre-fix). JS emits \\n where Rust now
;; correctly emits \n. Until JS template-content escaping is unified,
;; this test uses compile (JS-only).
;; per workbench/m16-formatting-divergences-diagnosis-cdc-review-2026-05-16.md
(test "tag: tag is a member expression"
  (bind result (compile "(tag String:raw (template \"\\n\"))"))
  (includes result "String.raw")
  (includes result "`"))

(test "tag: non-template second arg throws"
  (is-thrown (compile "(tag html \"not a template\")") Error))
