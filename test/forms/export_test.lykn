(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test-compiles "export: declaration"
  "(export (const x 42))" "export const x = 42;")

(test "export: function declaration"
  (bind result (compile-both "(export (function foo () (return 1)))"))
  (includes result "export function foo"))

(test-compiles "export: default expression"
  "(export default my-fn)" "export default myFn;")

(test "export: named bindings"
  (bind result (compile-both "(export (names a b))"))
  (includes result "a")
  (includes result "b"))

(test "export: named with alias"
  (bind result (compile-both "(export (names (alias my-func external-name)))"))
  (includes result "myFunc as externalName"))

(test "export: re-export from module"
  (bind result (compile-both "(export \"mod\" (names foo bar))"))
  (includes result "\"mod\"")
  (includes result "foo"))

(test "export: no args throws"
  (is-thrown (compile "(export)") Error))
