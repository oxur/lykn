(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test "for-of: basic"
  (bind result (compile-both "(for-of item items (console:log item))"))
  (includes result "for (const item of items)"))

(test "for-of: missing args throws"
  (is-thrown (compile "(for-of item)") Error))
