(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test "for: basic c-style"
  (bind result (compile-both "(for (let i 0) (< i 10) (++ i) (console:log i))"))
  (includes result "for")
  (includes result "i < 10"))

(test "for: infinite loop with empty slots"
  (bind result (compile-both "(for () () () (break))"))
  (includes result "for (; ; )"))

(test "for: missing body throws"
  (is-thrown (compile "(for (let i 0) (< i 10))") Error))
