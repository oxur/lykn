(import-macros "testing" (test includes))
(import "testing/helpers.js" (compile))

(test "->: thread-first basic"
  (bind r (compile "(-> 5 (+ 3) (* 2))"))
  (includes r "5 + 3"))

(test "->>: thread-last basic"
  (bind r (compile "(->> items (filter even?) (map double))"))
  (includes r "filter"))

(test "some->: nil-safe thread-first"
  (bind r (compile "(some-> user (get :name) (:to-upper-case))"))
  (includes r "null"))

(test "some->>: nil-safe thread-last"
  (bind r (compile "(some->> items (filter valid?) (map process))"))
  (includes r "null"))
