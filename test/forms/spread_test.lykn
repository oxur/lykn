(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test-compiles "spread: in array"
  "(array 1 2 (spread rest))" "[1, 2, ...rest];")

(test-compiles "spread: in function call"
  "(foo (spread args))" "foo(...args);")

(test-compiles "spread: in array at start"
  "(array (spread first) 4 5)" "[...first, 4, 5];")
