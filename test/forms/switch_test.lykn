(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test "switch: basic with default"
  (bind result (compile-both "(switch x (\"a\" (do-a) (break)) (\"b\" (do-b) (break)) (default (do-default)))"))
  (includes result "switch")
  (includes result "case \"a\"")
  (includes result "default:"))

(test "switch: missing cases throws"
  (is-thrown (compile "(switch x)") Error))
