(import-macros "testing" (test ok includes))
(import "testing/helpers.js" (compile compile-both))

;; DD-52 #3: Directory-path import resolution convergence.
;; Direction (a): JS aligned to Rust's find_macro_entry auto-resolve.
;;
;; Both compilers now resolve directory paths (e.g., "./packages/testing")
;; to mod.lykn automatically. compileBoth passes --source-context-path
;; so relative imports resolve from the project root.

(test
  "DD-52 #3: JS expander resolves directory-path import-macros"
  (bind r (compile "(import-macros \"./packages/testing\" (test is-equal))\n(test \"x\" (is-equal 1 1))"))
  (includes r "Deno.test")
  (includes r "assertEquals"))

(test
  "DD-52 #3: Rust compiler resolves directory-path via --source-context-path"
  (bind r (compile-both "(bind x 42)"))
  (includes r "const x = 42"))
