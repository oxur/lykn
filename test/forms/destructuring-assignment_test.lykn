(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

;; DD-58 deferral: kernel = is context-dependent (equality at top-level,
;; assignment inside blocks). The Rust compiler emits === unconditionally
;; for surface =. These tests use compile (JS-only) until DD-58 resolves
;; the = context-dependence properly.
;; per workbench/m16-formatting-divergences-diagnosis-cdc-review-2026-05-16.md

(test "assignment: object destructuring"
  (bind result (compile "(= (object a b) obj)"))
  (includes result "a")
  (includes result "= obj"))

(test "assignment: array destructuring"
  (bind result (compile-both "(= (array x y) pair)"))
  (includes result "[x, y]"))

(test-compiles "assignment: regular (non-destructuring) still works"
  "(= x 5)" "x = 5;")

(test "assignment: member expression still works"
  (bind result (compile "(= this:count 0)"))
  (includes result "this.count = 0"))
