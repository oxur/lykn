(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "../../packages/lang/mod.js" ((alias lykn compile)))

;; --- cell ---

(test-compiles "cell: create cell with number"
  "(cell 0)" "({\n  value: 0\n});")

(test-compiles "cell: create cell with string"
  "(cell \"hello\")" "({\n  value: \"hello\"\n});")

;; --- express ---

(test-compiles "express: read cell value"
  "(express counter)" "counter.value;")

;; --- swap! ---

(test-compiles "swap!: simple function"
  "(swap! counter inc)" "counter.value = inc(counter.value);")

(test-compiles "swap!: with extra args"
  "(swap! counter add 5)" "counter.value = add(counter.value, 5);")

(test-compiles "swap!: with multiple extra args"
  "(swap! counter f a b)" "counter.value = f(counter.value, a, b);")

(test-compiles "swap!: with lambda"
  "(swap! counter (=> (n) (+ n 1)))" "counter.value = (n => n + 1)(counter.value);")

;; --- reset! ---

(test-compiles "reset!: simple value"
  "(reset! counter 0)" "counter.value = 0;")

(test-compiles "reset!: expression value"
  "(reset! counter (+ a b))" "counter.value = a + b;")
