(import-macros "testing" (test test-compiles is-equal is-thrown includes))

(import "testing/helpers.js" (compile read expand reset-gensym reset-macros))

(test-compiles "bind: simple binding" "(bind x 42)" "const x = 42;")

(test-compiles
  "bind: string value"
  "(bind name \"Duncan\")"
  "const name = \"Duncan\";")

(test-compiles
  "bind: expression value"
  "(bind result (+ 1 2))"
  "const result = 1 + 2;")

(test-compiles
  "bind: with type annotation"
  "(bind :number age 42)"
  "const age = 42;")

(test
  "bind: with type annotation and expression — emits runtime check"
  (bind result (compile "(bind :string name (get-name user))"))
  (includes result "const name = getName(user);")
  (includes result "typeof name !== \"string\"")
  (includes result "TypeError"))

(test-compiles
  "bind: type annotation on literal — no runtime check"
  "(bind :string name \"hello\")"
  "const name = \"hello\";")

(test-compiles
  "bind: :any annotation — no runtime check"
  "(bind :any x (compute))"
  "const x = compute();")

(test
  "bind: type mismatch on literal — compile error"
  (is-thrown (compile "(bind :number x \"hello\")") Error))

(test-compiles "bind: kebab-case name" "(bind my-value 10)" "const myValue = 10;")

(test
  "bind: expansion produces const form"
  (reset-macros)
  (reset-gensym)
  (bind result (expand (read "(bind x 42)")))
  (bind form (get result 0))
  (bind head (get form:values 0))
  (bind name-node (get form:values 1))
  (bind val-node (get form:values 2))
  (is-equal head:value "const")
  (is-equal name-node:value "x")
  (is-equal val-node:value 42))

(test
  "bind: typed expansion drops type keyword"
  (reset-macros)
  (reset-gensym)
  (bind result (expand (read "(bind :number x 42)")))
  (bind form (get result 0))
  (bind head (get form:values 0))
  (bind name-node (get form:values 1))
  (bind val-node (get form:values 2))
  (is-equal head:value "const")
  (is-equal name-node:value "x")
  (is-equal val-node:value 42))
