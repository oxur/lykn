(import-macros "testing" (test test-compiles is-equal is-thrown includes))

(import "testing/helpers.js" (compile))

(test
  "type: single constructor with field"
  (bind result (compile "(type Wrapper (Wrap :any value))"))
  (includes result "function Wrap(value)")
  (includes result "tag: \"Wrap\"")
  (includes result "return"))

(test
  "type: zero-field constructor"
  (bind result (compile "(type Unit Empty)"))
  (includes result "const Empty = {\n  tag: \"Empty\"\n}"))

(test
  "type: Option with Some and None"
  (bind result (compile "(type Option (Some :any value) None)"))
  (includes result "function Some(value)")
  (includes result "tag: \"Some\"")
  (includes result "tag: \"None\"")
  (includes result "const None"))

(test
  "type: typed fields emit type checks"
  (bind result (compile "(type Point (Pt :number x :number y))"))
  (includes result "typeof x !== \"number\"")
  (includes result "typeof y !== \"number\""))

(test
  "type: :any fields skip type checks"
  (bind result (compile "(type Box (Box :any value))"))
  (includes result "function Box(value)")
  (includes result "tag: \"Box\""))

(test
  "type: multi-field constructor"
  (bind result (compile "(type Pair (Pair :any first :any second))"))
  (includes result "function Pair(first, second)")
  (includes result "first: first")
  (includes result "second: second"))

(test
  "type: Result with Ok and Err"
  (bind result (compile "(type Result (Ok :any value) (Err :any error))"))
  (includes result "function Ok(value)")
  (includes result "function Err(error)")
  (includes result "tag: \"Ok\"")
  (includes result "tag: \"Err\""))

(type Color Red Green Blue)

(test
  "type runtime: zero-field constructors are accessible"
  (is-equal Red:tag "Red")
  (is-equal Green:tag "Green")
  (is-equal Blue:tag "Blue"))

(type Option (Some :any value) None)

(test
  "type runtime: constructor with field"
  (bind s (Some 42))
  (is-equal s:tag "Some")
  (is-equal s:value 42))

(test "type runtime: zero-field constructor value" (is-equal None:tag "None"))

(test
  "type runtime: match on ADT"
  (bind result (match (Some 10) ((Some v) (+ v 1)) (None 0)))
  (is-equal result 11))

(test
  "type runtime: match on zero-field"
  (bind result (match None ((Some v) v) (None "empty")))
  (is-equal result "empty"))

(type Shape (Circle :number radius) (Rect :number width :number height))

(test
  "type runtime: typed fields"
  (bind c (Circle 5))
  (is-equal c:tag "Circle")
  (is-equal c:radius 5))

(test
  "type runtime: multi-field constructor"
  (bind r (Rect 3 4))
  (is-equal r:width 3)
  (is-equal r:height 4))

(test
  "type runtime: match with multiple constructors"
  (func
    area
    :args
    (:any shape)
    :returns
    :number
    :body
    (match shape ((Circle r) (* 3 r r)) ((Rect w h) (* w h))))
  (is-equal (area (Circle 10)) 300)
  (is-equal (area (Rect 3 4)) 12))
