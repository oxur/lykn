(import-macros "testing" (test includes))
(import "testing/helpers.js" ((alias compile-kernel compile) compile-both))

(test "const: basic declaration"
  (const result (compile-both "(const x 42)"))
  (includes result "const x = 42"))

(test "const: string value"
  (const result (compile "(const name \"hello\")"))
  (includes result "const name"))
