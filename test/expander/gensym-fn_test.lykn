(import-macros "testing" (test is-equal))
(import "../../packages/lang/reader.js" (read))
(import "../../packages/lang/expander.js" (expand reset-gensym reset-macros))
(import "../../packages/lang/compiler.js" (compile))

(func lykn
  :args (:string source)
  :body
  (reset-macros)
  (reset-gensym)
  (bind raw (compile (expand (read source))))
  (raw:trim))

(test "gensym function: available in macro body"
  (bind result (lykn "
    (macro with-temp (val (rest body))
      (const tmp ($gensym \"tmp\"))
      `(block (let ,tmp ,val) ,@body))
    (with-temp 42 (console:log \"done\"))
  "))
  (is-equal (result:includes "tmp__gensym") true))

(test "gensym function: default prefix"
  (bind result (lykn "
    (macro with-gen (val)
      (const tmp ($gensym))
      `(let ,tmp ,val))
    (with-gen 99)
  "))
  (is-equal (result:includes "g__gensym") true))
