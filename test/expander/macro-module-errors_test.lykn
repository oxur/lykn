(import-macros "testing" (test is-thrown))
(import "../../packages/lang/reader.js" (read))
(import "../../packages/lang/expander.js" (expand reset-gensym reset-macros reset-module-cache))
(import "node:path" (resolve))

(bind fixtures-dir (resolve import:meta:dirname "../fixtures/macros"))

(func ex
  :args (:string source :string file-path)
  :body
  (reset-macros)
  (reset-gensym)
  (reset-module-cache)
  (expand (read source) (obj :file-path file-path)))

(test "import-macros error: file not found"
  (is-thrown
    (ex "(import-macros \"./nonexistent.lykn\" (foo))" (resolve fixtures-dir "test.lykn"))
    Error "not found"))

(test "import-macros error: macro not exported"
  (is-thrown
    (ex "(import-macros \"./unexported.lykn\" (internal-only))" (resolve fixtures-dir "test.lykn"))
    Error "not exported"))

(test "import-macros error: circular dependency"
  (is-thrown
    (ex "(import-macros \"./circular-a.lykn\" (foo))" (resolve fixtures-dir "test.lykn"))
    Error "circular"))

(test "import-macros error: duplicate import of same path"
  (is-thrown
    (ex
      "(import-macros \"./basic-control.lykn\" (when))
       (import-macros \"./basic-control.lykn\" (unless))"
      (resolve fixtures-dir "test.lykn"))
    Error "duplicate"))

(test "import-macros error: missing binding list"
  (is-thrown
    (ex "(import-macros \"./basic-control.lykn\")" (resolve fixtures-dir "test.lykn"))
    Error "binding list"))

(test "import-macros error: bare name not found"
  (is-thrown
    (ex "(import-macros \"basic-control.lykn\" (when))" (resolve fixtures-dir "test.lykn"))
    Error "could not resolve"))

(test "import-macros error: invalid path (no .lykn extension)"
  (is-thrown
    (ex "(import-macros \"./basic-control.js\" (when))" (resolve fixtures-dir "test.lykn"))
    Error ".lykn"))

(test "import-macros error: shadowing imported macro"
  (is-thrown
    (ex
      "(import-macros \"./basic-control.lykn\" (when))
       (macro when (test (rest body)) `(if ,test (block ,@body)))"
      (resolve fixtures-dir "test.lykn"))
    Error "duplicate"))
